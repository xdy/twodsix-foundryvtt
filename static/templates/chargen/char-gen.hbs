<div class="cg-app">
  <div class="cg-header">
    <div class="cg-header-row">
      <label>{{localize "TWODSIX.CharGen.App.SelectRuleset"}}
        <select class="cg-ruleset">
          {{#each rulesets}}
            <option value="{{key}}"
              {{#if selected}}selected{{/if}}
              {{#if disabled}}disabled{{/if}}>{{name}}</option>
          {{/each}}
        </select>
      </label>
      <span>{{localize "TWODSIX.CharGen.App.Age"}} <strong>{{age}}</strong></span>
      <span>{{localize "TWODSIX.CharGen.App.Terms"}} <strong>{{totalTerms}}</strong></span>
      <span>{{localize "TWODSIX.CharGen.App.SkillsCount"}} <strong>{{skls}}</strong></span>
      {{#if showChargenRandomRoll}}
        <button type="button" class="cg-rand-all cg-auto-btn" title="{{localize "TWODSIX.CharGen.App.RandomAll"}}">
          <i class="fas fa-dice"></i> {{localize "TWODSIX.CharGen.App.RandomAll"}}
        </button>
      {{/if}}
    </div>
  </div>

  <div class="cg-scroll" style="flex: {{scrollFlex}}">
    <table class="cg-table">
      <tbody>
      {{#each rows}}
        {{#if (eq rowType 'characteristics')}}
          <tr class="{{#if active}}cg-row-active{{/if}}" data-row-type="characteristics">
            <td class="cg-td-label{{#if active}}--active{{/if}}">{{label}}</td>
            <td class="cg-td-value">
              {{#if active}}
                <div class="cg-char-row">
                  <button type="button" class="cg-roll-upp cg-btn-icon"
                          title="{{localize "TWODSIX.CharGen.App.RollUpp"}}"
                          tabindex="-1">
                    <i class="fas fa-dice-six"></i>
                  </button>
                  {{#each ../chars}}
                    <input type="number" class="cg-char-input" data-char-key="{{key}}" value="{{value}}"
                           min="{{../charInputMin}}"
                           max="{{../charInputMax}}" placeholder="?">
                  {{/each}}
                  {{#if ../isPointBuy}}
                    <span class="cg-point-buy-total">{{localize "TWODSIX.CharGen.App.Points"}}: {{../remainingPoints}}
                      / {{../pointBuyTotal}}</span>
                  {{/if}}
                  {{#if ../showChargenUndo}}
                    <button type="button" class="cg-undo cg-btn-action" tabindex="-1">&#8617; {{localize
                      "TWODSIX.CharGen.App.Undo"}}</button>
                  {{/if}}
                  {{#if ../showChargenRandomRoll}}
                    <button type="button" class="cg-auto-from-here cg-btn-icon"
                            title="{{localize "TWODSIX.CharGen.App.AutoFromHere"}}"
                            tabindex="-1">
                      <i class="fas fa-dice"></i>
                    </button>
                  {{/if}}
                  <button type="button" class="cg-char-done cg-btn-action" tabindex="-1" disabled>{{localize
                    "TWODSIX.CharGen.App.CharDone"}}</button>
                </div>
              {{else}}
                <div class="cg-char-display">
                  {{#each ../chars}}
                    <span class="cg-char-display-item" title="{{key}}">{{value}}</span>
                  {{/each}}
                </div>
              {{/if}}
            </td>
          </tr>
        {{else if (eq rowType 'name')}}
          <tr class="{{#if active}}cg-row-active{{/if}}">
            <td class="cg-td-label{{#if active}}--active{{/if}}">{{label}}</td>
            <td class="{{#if active}}cg-td-controls{{else}}cg-td-value{{/if}}">
              {{#if active}}
                <button type="button" class="cg-name-roll cg-btn-icon"
                        title="{{localize "TWODSIX.CharGen.App.RollName"}}"
                        tabindex="-1">
                  <i class="fas fa-dice-six"></i>
                </button>
                <input type="text" class="cg-name-input"
                       placeholder="{{localize "TWODSIX.CharGen.App.NamePlaceholder"}}">
                {{#if ../showChargenUndo}}
                  <button type="button" class="cg-undo cg-btn-action" tabindex="-1">&#8617; {{localize
                    "TWODSIX.CharGen.App.Undo"}}</button>
                {{/if}}
                {{#if ../showChargenRandomRoll}}
                  <button type="button" class="cg-auto-from-here cg-btn-icon"
                          title="{{localize "TWODSIX.CharGen.App.AutoFromHere"}}"
                          tabindex="-1">
                    <i class="fas fa-dice"></i>
                  </button>
                {{/if}}
                <button type="button" class="cg-name-done cg-btn-action" tabindex="-1" disabled>{{localize
                  "TWODSIX.CharGen.App.CharDone"}}</button>
              {{else}}
                {{result}}
              {{/if}}
            </td>
          </tr>
        {{else if active}}
          <tr class="cg-row-active">
            <td class="cg-td-label--active">{{label}}</td>
            <td class="cg-td-controls">
              {{#if ../showChargenRandomRoll}}
                <button type="button" class="cg-rand cg-btn-icon" title="{{localize "TWODSIX.CharGen.App.Random"}}"
                        tabindex="-1">
                  <i class="fas fa-dice-six"></i>
                </button>
              {{/if}}
              <select class="cg-select">
                <option value="">{{localize "TWODSIX.CharGen.App.ChooseOption"}}</option>
                {{#each options}}
                  <option value="{{value}}">{{label}}</option>
                {{/each}}
              </select>
              {{#if ../showChargenUndo}}
                <button type="button" class="cg-undo cg-btn-action" tabindex="-1">&#8617; {{localize
                  "TWODSIX.CharGen.App.Undo"}}</button>
              {{/if}}
              {{#if ../showChargenRandomRoll}}
                <button type="button" class="cg-auto-from-here cg-btn-icon"
                        title="{{localize "TWODSIX.CharGen.App.AutoFromHere"}}" tabindex="-1">
                  <i class="fas fa-dice"></i>
                </button>
              {{/if}}
            </td>
          </tr>
        {{else}}
          <tr>
            <td class="cg-td-label">{{label}}</td>
            <td class="cg-td-value">{{result}}</td>
          </tr>
        {{/if}}
      {{/each}}
      </tbody>
    </table>
  </div>

  {{#if isDone}}
    <div class="cg-resize-handle"></div>
    <div class="cg-summary-title">{{#if died}}{{localize "TWODSIX.CharGen.App.Epitaph"}}{{else}}{{localize
      "TWODSIX.CharGen.App.CharacterSummary"}}{{/if}}</div>
    <div class="cg-summary-body" style="height: {{summaryHeight}}px">{{textSummary}}</div>
    <div class="cg-footer">
      {{#if showChargenUndo}}
        <button type="button" class="cg-undo cg-create-btn">&#8617; {{localize "TWODSIX.CharGen.App.Undo"}}</button>
      {{/if}}
      <button type="button" class="cg-create cg-create-btn">&#10003; {{localize "TWODSIX.CharGen.App.CreateActor"}}
        : {{charName}}</button>
      <button type="button" class="cg-redo cg-create-btn">&#8634; {{localize "TWODSIX.CharGen.App.Redo"}}</button>
    </div>
  {{else}}
    <div class="cg-footer-progress">{{localize "TWODSIX.CharGen.App.GenerationInProgress"}}</div>
  {{/if}}
</div>
