<div class="cg-app">
  <div class="cg-header">
    <div class="cg-header-row">
      <label>Ruleset
        <select class="cg-ruleset">
          {{#each rulesets}}
            <option value="{{key}}"
              {{#if selected}}selected{{/if}}
              {{#if disabled}}disabled{{/if}}>{{name}}</option>
          {{/each}}
        </select>
      </label>
      <label>Language
        <button type="button" class="cg-roll-lang cg-btn-icon" title="Random Language" tabindex="-1">
          <i class="fas fa-dice"></i>
        </button>
        <select class="cg-lang-select">
          {{#each languages}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <label>Name
        <button type="button" class="cg-roll-name cg-btn-icon" title="Random Name" tabindex="-1">
          <i class="fas fa-dice"></i>
        </button>
        <input class="cg-name" type="text" value="{{charName}}">
      </label>
      <span>Age <strong>{{age}}</strong></span>
      <span>Skills <strong>{{skls}}</strong></span>
      <button type="button" class="cg-rand-all cg-auto-btn" title="Auto-generate (random choices)">
        <i class="fas fa-dice"></i> Auto
      </button>
    </div>
  </div>

  <div class="cg-scroll" style="flex: {{scrollFlex}}">
    <table class="cg-table">
      <tbody>
      {{#each rows}}
        {{#if (eq label 'Characteristics')}}
          <tr class="{{#if active}}cg-row-active{{/if}}" data-row-type="characteristics">
            <td class="cg-td-label{{#if active}}--active{{/if}}">{{label}}</td>
            <td class="cg-td-value">
              {{#if active}}
                <div class="cg-char-row">
                  <button type="button" class="cg-roll-upp cg-btn-icon" title="Random UPP" tabindex="-1">
                    <i class="fas fa-dice-six"></i>
                  </button>
                  {{#each ../chars}}
                    <input type="number" class="cg-char-input" data-char-key="{{key}}" value="{{value}}" min="1" max="15" placeholder="?">
                  {{/each}}
                  <button type="button" class="cg-auto-from-here cg-btn-icon" title="Auto-generate from here" tabindex="-1">
                    <i class="fas fa-dice"></i>
                  </button>
                  <button type="button" class="cg-char-done cg-btn-action" tabindex="-1" disabled>Done</button>
                </div>
              {{else}}
                <div class="cg-char-display">
                  {{#each ../chars}}
                    <span class="cg-char-display-item" title="{{key}}">{{value}}</span>
                  {{/each}}
                </div>
              {{/if}}
            </td>
          </tr>
        {{else if active}}
          <tr class="cg-row-active">
            <td class="cg-td-label--active">{{label}}</td>
            <td class="cg-td-controls">
              <button type="button" class="cg-rand cg-btn-icon" title="Pick Random" tabindex="-1">
                <i class="fas fa-dice-six"></i>
              </button>
              <select class="cg-select">
                <option value="">— choose —</option>
                {{#each options}}
                  <option value="{{value}}">{{label}}</option>
                {{/each}}
              </select>
              <button type="button" class="cg-undo cg-btn-action" tabindex="-1">↩ Undo</button>
              <button type="button" class="cg-auto-from-here cg-btn-icon" title="Auto-generate from here" tabindex="-1">
                <i class="fas fa-dice"></i>
              </button>
            </td>
          </tr>
        {{else}}
          <tr>
            <td class="cg-td-label">{{label}}</td>
            <td class="cg-td-value">{{result}}</td>
          </tr>
        {{/if}}
      {{/each}}
      </tbody>
    </table>
  </div>

  {{#if isDone}}
    <div class="cg-resize-handle"></div>
    <div class="cg-summary-title">{{#if died}}Epitaph{{else}}Character Summary{{/if}}</div>
    <div class="cg-summary-body" style="height: {{summaryHeight}}px">{{textSummary}}</div>
    <div class="cg-footer">
      <button type="button" class="cg-create cg-create-btn">✓ Create Actor: {{charName}}</button>
      {{#if autoAll}}
        <button type="button" class="cg-redo cg-create-btn">↺ Redo</button>
      {{/if}}
    </div>
  {{else}}
    <div class="cg-footer-progress">Generation in progress…</div>
  {{/if}}
</div>
