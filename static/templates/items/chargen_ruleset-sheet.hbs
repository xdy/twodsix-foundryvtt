<section class="{{cssClass}} item-class" autocomplete="off">
  {{> "systems/twodsix/templates/items/parts/image-name.hbs"}}
  {{> "systems/twodsix/templates/items/parts/item-type.hbs"}}

  {{#if settings.useTabbedViews}}
    <nav class="sheet-tabs tabs" data-group="primary">
      {{~#each tabs.primary.tabs}}
        <a class="{{this.cssClass}}" data-action="tab" data-group="{{this.group}}" data-tab="{{this.id}}">
          <i class="{{this.icon}}"></i>
          <label>{{localize this.label}}</label>
        </a>
      {{/each~}}
    </nav>
  {{/if}}

  <section class="sheet-body">
    {{!-- Description Tab --}}
    <div class="tab {{#if settings.useTabbedViews}}{{#if (eq tabs.primary.active "description")}}active{{/if}}{{else}}active{{/if}}"
         data-group="primary" data-tab="description">
      <div class="item-descr">
        <span class="resource-label">{{localize "TWODSIX.Items.Equipment.Description"}}</span>
        <prose-mirror name="system.description" data-document-u-u-i-d="{{item.uuid}}"
                      value="{{item.system.description}}" collaborate="true" toggled="true">
          {{{enrichedDescription}}}
        </prose-mirror>
      </div>
    </div>

    {{!-- Chargen Ruleset Data Tab --}}
    <div class="tab {{#if settings.useTabbedViews}}{{#if (eq tabs.primary.active "chargenRuleset")}}active{{/if}}{{else}}active{{/if}}"
         data-group="primary" data-tab="chargenRuleset">
      <div class="career-grid">

        {{!-- Ruleset identifier --}}
        <div class="career-check-group">
          <div class="career-check" style="display: flex; align-items: center; gap: 8px;">
            <label style="min-width: 120px;">{{localize "TWODSIX.Items.ChargenRuleset.Ruleset"}}:</label>
            <input type="text" name="system.ruleset" value="{{item.system.ruleset}}" style="width: 80px;"/>
          </div>
        </div>

        {{!-- Aging Table --}}
        <div class="career-tables">
          <span class="resource-label">{{localize "TWODSIX.Items.ChargenRuleset.AgingTable"}}</span>
          {{#each item.system.agingTable}}
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 2px;">
              <span style="min-width: 32px; font-weight: bold;">{{@index}}:</span>
              {{#if this.noEffect}}
                <span>{{localize "TWODSIX.Items.ChargenRuleset.NoEffect"}}</span>
                <input type="hidden" name="system.agingTable.{{@index}}.noEffect" value="true"/>
                <input type="hidden" name="system.agingTable.{{@index}}.physStr" value="0"/>
                <input type="hidden" name="system.agingTable.{{@index}}.physDex" value="0"/>
                <input type="hidden" name="system.agingTable.{{@index}}.physEnd" value="0"/>
                <input type="hidden" name="system.agingTable.{{@index}}.mental" value="0"/>
              {{else}}
                <label style="min-width: 36px;">STR</label>
                <input type="number" name="system.agingTable.{{@index}}.physStr" value="{{this.physStr}}" style="width: 48px;"/>
                <label style="min-width: 36px;">DEX</label>
                <input type="number" name="system.agingTable.{{@index}}.physDex" value="{{this.physDex}}" style="width: 48px;"/>
                <label style="min-width: 36px;">END</label>
                <input type="number" name="system.agingTable.{{@index}}.physEnd" value="{{this.physEnd}}" style="width: 48px;"/>
                <label style="min-width: 52px;">Mental</label>
                <input type="number" name="system.agingTable.{{@index}}.mental" value="{{this.mental}}" style="width: 48px;"/>
                <input type="hidden" name="system.agingTable.{{@index}}.noEffect" value="false"/>
              {{/if}}
            </div>
          {{/each}}
        </div>

        {{!-- Mishap Table --}}
        <div class="career-tables">
          <span class="resource-label">{{localize "TWODSIX.Items.ChargenRuleset.MishapTable"}}</span>
          {{#each item.system.mishapDesc}}
            {{#unless @first}}
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 2px;">
                <span style="min-width: 24px; font-weight: bold;">{{@index}}.</span>
                <input type="text" name="system.mishapDesc.{{@index}}" value="{{this}}" style="flex: 1;"/>
              </div>
            {{/unless}}
          {{/each}}
        </div>

        {{!-- Injury Table --}}
        <div class="career-tables">
          <span class="resource-label">{{localize "TWODSIX.Items.ChargenRuleset.InjuryTable"}}</span>
          {{#each item.system.injuryDesc}}
            {{#unless @first}}
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 2px;">
                <span style="min-width: 24px; font-weight: bold;">{{@index}}.</span>
                <input type="text" name="system.injuryDesc.{{@index}}" value="{{this}}" style="flex: 1;"/>
              </div>
            {{/unless}}
          {{/each}}
        </div>

        {{!-- Draft Table --}}
        <div class="career-tables">
          <span class="resource-label">{{localize "TWODSIX.Items.ChargenRuleset.DraftTable"}}</span>
          {{#each item.system.draftTable}}
            {{#unless @first}}
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 2px;">
                <span style="min-width: 24px; font-weight: bold;">{{@index}}.</span>
                <input type="text" name="system.draftTable.{{@index}}" value="{{this}}" style="flex: 1;"/>
              </div>
            {{/unless}}
          {{/each}}
        </div>

        {{!-- Cascade Skills --}}
        <div class="career-tables">
          <span class="resource-label">{{localize "TWODSIX.Items.ChargenRuleset.CascadeSkills"}}</span>
          {{#each item.system.cascadeSkills}}
            <div style="margin-bottom: 6px;">
              <input type="text" name="system.cascadeSkills.{{@index}}.skill" value="{{this.skill}}"
                     style="width: 180px; font-weight: bold;"
                     placeholder="{{localize 'TWODSIX.Items.ChargenRuleset.CascadeSkill'}}"/>
              <div style="margin-left: 16px;">
                {{#each this.specializations}}
                  <input type="text" name="system.cascadeSkills.{{lookup ../. '@index'}}.specializations.{{@index}}"
                         value="{{this}}" style="width: 200px; margin: 1px 2px;"/>
                {{/each}}
              </div>
            </div>
          {{/each}}
        </div>

        {{!-- Homeworld Descriptors --}}
        <div class="career-tables">
          <span class="resource-label">{{localize "TWODSIX.Items.ChargenRuleset.HomeworldDescriptors"}}</span>
          {{#each item.system.homeworldDescriptors}}
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 2px;">
              <input type="text" name="system.homeworldDescriptors.{{@index}}.descriptor"
                     value="{{this.descriptor}}" style="width: 160px;"
                     placeholder="{{localize 'TWODSIX.Items.ChargenRuleset.Descriptor'}}"/>
              <span>→</span>
              <input type="text" name="system.homeworldDescriptors.{{@index}}.skill"
                     value="{{this.skill}}" style="width: 160px;"/>
            </div>
          {{/each}}
        </div>

        {{!-- Education Skills --}}
        <div class="career-tables">
          <span class="resource-label">{{localize "TWODSIX.Items.ChargenRuleset.EducationSkills"}}</span>
          {{#each item.system.educationSkills}}
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 2px;">
              <span style="min-width: 24px; font-weight: bold;">{{add @index 1}}.</span>
              <input type="text" name="system.educationSkills.{{@index}}" value="{{this}}" style="flex: 1;"/>
            </div>
          {{/each}}
        </div>

        {{!-- Skill Name Map --}}
        <div class="career-tables">
          <span class="resource-label">{{localize "TWODSIX.Items.ChargenRuleset.SkillNameMap"}}</span>
          {{#each item.system.skillNameMap}}
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 2px;">
              <input type="text" name="system.skillNameMap.{{@index}}.from" value="{{this.from}}"
                     style="width: 160px;"
                     placeholder="{{localize 'TWODSIX.Items.ChargenRuleset.SkillNameFrom'}}"/>
              <span>→</span>
              <input type="text" name="system.skillNameMap.{{@index}}.to" value="{{this.to}}"
                     style="width: 200px;"/>
            </div>
          {{/each}}
        </div>

        {{!-- Char Key Map --}}
        <div class="career-tables">
          <span class="resource-label">{{localize "TWODSIX.Items.ChargenRuleset.CharKeyMap"}}</span>
          {{#each item.system.charKeyMap}}
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 2px;">
              <input type="text" name="system.charKeyMap.{{@index}}.benefit" value="{{this.benefit}}"
                     style="width: 120px;"
                     placeholder="{{localize 'TWODSIX.Items.ChargenRuleset.Benefit'}}"/>
              <span>→</span>
              <input type="text" name="system.charKeyMap.{{@index}}.key" value="{{this.key}}"
                     style="width: 60px;"/>
            </div>
          {{/each}}
        </div>

      </div>
    </div>
  </section>

  {{> "systems/twodsix/templates/items/parts/reference-footer.hbs"}}
  {{#if settings.useItemAEs}}{{> "systems/twodsix/templates/items/parts/footer.hbs"}}{{/if}}
</section>
