<section class="{{cssClass}} item-class" autocomplete="off">
  {{> "systems/twodsix/templates/items/parts/image-name.hbs"}}

  <div class="item-short">
    <label for="system.shortdescr" class="resource-label">{{localize
      "TWODSIX.Items.Equipment.ShortDescription"}}</label>
    <input class="form-input" type="text" name="system.shortdescr" value="{{system.shortdescr}}"/>
  </div>

  <div class="item-descr">
    <span class="resource-label">{{localize "TWODSIX.Items.Equipment.Description"}}</span>
    <prose-mirror name="system.description" data-document-u-u-i-d="{{item.uuid}}"
                  value="{{system.description}}" collaborate="true" toggled="true">
      {{{enrichedDescription}}}
    </prose-mirror>
  </div>

  {{!-- Characteristic Modifiers (Deltas) --}}
  <fieldset>
    <legend class="resource-label">{{localize "TWODSIX.Items.Species.CharacteristicModifiers"}}</legend>
    <div class="species-deltas">
      {{#each deltaCharacteristics}}
        <div class="species-delta">
          <label for="system.deltas.{{@key}}" class="resource-label">{{this.label}}</label>
          <input class="form-input" type="number" name="system.deltas.{{@key}}"
                 value="{{this.value}}" data-dtype="Number"/>
        </div>
      {{/each}}
    </div>
  </fieldset>

  {{!-- Homeworld --}}
  <div class="item-homeworld">
    <label for="system.homeworld" class="resource-label">{{localize "TWODSIX.Items.Species.Homeworld"}}</label>
    <input class="form-input" type="text" name="system.homeworld" value="{{system.homeworld}}"/>
  </div>

  {{!-- Ruleset --}}
  {{#if speciesRulesets.length}}
    <div class="item-ruleset">
      <label for="system.ruleset" class="resource-label">{{localize "TWODSIX.Items.Species.Ruleset"}}</label>
      <select class="form-input" name="system.ruleset">
        {{#each speciesRulesets}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
        {{/each}}
        <option value="" {{#unless item.system.ruleset}}selected{{/unless}}>—</option>
      </select>
    </div>
  {{/if}}

  {{!-- Aging Roll Bonus --}}
  <div class="item-aging">
    <label for="system.agingRollBonus" class="resource-label">{{localize
      "TWODSIX.Items.Species.AgingRollBonus"}}</label>
    <input class="form-input" type="number" name="system.agingRollBonus" value="{{system.agingRollBonus}}"
           data-dtype="Number"/>
  </div>

  {{!-- Granted Trait Names --}}
  <fieldset>
    <legend class="resource-label">
      {{localize "TWODSIX.Items.Species.GrantedTraitNames"}}
      <a class="item-control" data-species-add-row="grantedTraitNames"
         data-tooltip="{{localize "TWODSIX.Items.Species.AddRow"}}"><i class="fa-solid fa-plus"></i></a>
    </legend>
    <div class="species-trait-names">
      {{#each system.grantedTraitNames}}
        <div class="species-array-row" style="display:flex; gap:4px; align-items:center;">
          <input class="form-input" type="text" name="system.grantedTraitNames.{{@index}}" value="{{this}}"
                 placeholder="{{localize "TWODSIX.Items.Species.TraitNamePlaceholder"}}"/>
          <a class="item-control" data-species-remove-row="grantedTraitNames" data-index="{{@index}}"
             data-tooltip="{{localize "TWODSIX.Items.Species.RemoveRow"}}"><i class="fa-solid fa-trash"></i></a>
        </div>
      {{/each}}
    </div>
  </fieldset>

  {{!-- Ability Lines --}}
  <fieldset>
    <legend class="resource-label">
      {{localize "TWODSIX.Items.Species.AbilityLines"}}
      <a class="item-control" data-species-add-row="abilityLines"
         data-tooltip="{{localize "TWODSIX.Items.Species.AddRow"}}"><i class="fa-solid fa-plus"></i></a>
    </legend>
    <div class="species-ability-lines">
      {{#each system.abilityLines}}
        <div class="species-array-row" style="display:flex; gap:4px; align-items:center;">
          <input class="form-input" type="text" name="system.abilityLines.{{@index}}" value="{{this}}"
                 placeholder="{{localize "TWODSIX.Items.Species.AbilityLinePlaceholder"}}"/>
          <a class="item-control" data-species-remove-row="abilityLines" data-index="{{@index}}"
             data-tooltip="{{localize "TWODSIX.Items.Species.RemoveRow"}}"><i class="fa-solid fa-trash"></i></a>
        </div>
      {{/each}}
    </div>
  </fieldset>

  {{!-- Allowed Careers --}}
  <fieldset>
    <legend class="resource-label">
      {{localize "TWODSIX.Items.Species.AllowedCareers"}}
      <a class="item-control" data-species-add-row="allowedCareers"
         data-tooltip="{{localize "TWODSIX.Items.Species.AddRow"}}"><i class="fa-solid fa-plus"></i></a>
    </legend>
    <div class="species-allowed-careers">
      {{#each system.allowedCareers}}
        <div class="species-array-row" style="display:flex; gap:4px; align-items:center;">
          <input class="form-input" type="text" name="system.allowedCareers.{{@index}}" value="{{this}}"
                 placeholder="{{localize "TWODSIX.Items.Species.CareerPlaceholder"}}"/>
          <a class="item-control" data-species-remove-row="allowedCareers" data-index="{{@index}}"
             data-tooltip="{{localize "TWODSIX.Items.Species.RemoveRow"}}"><i class="fa-solid fa-trash"></i></a>
        </div>
      {{/each}}
    </div>
  </fieldset>

  {{> "systems/twodsix/templates/items/parts/reference-footer.hbs"}}
  {{#if settings.useItemAEs}}{{> "systems/twodsix/templates/items/parts/footer.hbs"}}{{/if}}
</section>
