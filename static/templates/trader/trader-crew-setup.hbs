<div class="trader-crew-setup">
  <p class="trader-crew-hint">
    {{localize "TWODSIX.Trader.CrewSetup.Hint"}}
  </p>
  <table class="trader-crew-table">
    <thead>
    <tr>
      <th>{{localize "TWODSIX.Trader.CrewSetup.Position"}}</th>
      <th>{{localize "TWODSIX.Trader.CrewSetup.SalaryPerMonth"}}</th>
      <th>{{localize "TWODSIX.Trader.CrewSetup.ActorOrManualName"}}</th>
      {{#each skillNames}}
        <th>{{label}}</th>
      {{/each}}
      <th></th>
    </tr>
    </thead>
    <tbody>
    {{#each positions}}
      <tr class="trader-crew-row" data-position="{{position}}">
        <td class="trader-crew-pos">{{label}}</td>
        <td class="trader-crew-salary">Cr{{salary}}</td>
        <td class="trader-crew-assign">
          <select class="st-actor-select" data-position="{{position}}" {{#if locked}}disabled{{/if}}>
            <option value="">{{localize "TWODSIX.Trader.CrewSetup.ManualEntry"}}</option>
            {{#each actors}}
              <option value="{{id}}" {{#if selected}}selected{{/if}} title="{{skillTooltip}}" class="{{#if hasRelevantSkill}}st-has-relevant-skill{{/if}}">{{name}}</option>
            {{/each}}
          </select>
          <input class="st-name-input" type="text"
                 data-position="{{position}}"
                 value="{{manualName}}"
                 placeholder="{{label}}"
                 {{#if locked}}disabled{{/if}}/>
        </td>
        {{#each skillList}}
          <td class="trader-crew-skill">
            <input class="st-skill-input" type="number"
                   data-position="{{../position}}"
                   data-skill="{{key}}"
                   value="{{value}}" min="0" max="4"
                   {{#if ../locked}}disabled{{/if}}/>
          </td>
        {{/each}}
        <td class="trader-crew-clear-cell">
          <button type="button" class="st-clear-btn"
                  data-position="{{position}}"
                  data-tooltip="{{localize "TWODSIX.Trader.CrewSetup.ClearCrewMemberHint"}}"
                  {{#unless hasClearableContent}}disabled{{/unless}}>
            <i class="fa-solid fa-trash"></i>
          </button>
        </td>
      </tr>
    {{/each}}
    </tbody>
  </table>
  <div class="trader-crew-footer">
    <button type="button" class="st-chargen-btn">
      <i class="fas fa-user-plus"></i> {{localize "TWODSIX.Trader.CrewSetup.OpenCharacterGeneration"}}
    </button>
    <button type="button" class="st-refresh-btn">
      <i class="fas fa-sync"></i> {{localize "TWODSIX.Trader.CrewSetup.RefreshActors"}}
    </button>
    <button type="button" class="st-confirm-btn">
      <i class="fas fa-check"></i> {{localize "TWODSIX.Trader.CrewSetup.ConfirmCrew"}}
    </button>
  </div>
</div>
