{
  "private": true,
  "name": "twodsix",
  "version": "7.5.2",
  "description": "A 2d6 system",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "scripts": {
    "build": "pnpm run packs:build && vite build",
    "build:develop": "pnpm run packs:build-no-wiki && vite build",
    "packs:build-no-wiki": "node scripts/pack-management/packs.mjs build-no-wiki",
    "build:watch": "vite build --watch",
    "link:system": "node scripts/localdev/link-project.mjs",
    "link:intellisense": "node scripts/localdev/create-symlinks.mjs",
    "link": "pnpm run link:system",
    "link-project": "pnpm run link:system",
    "symlinks": "pnpm run link:intellisense",
    "clean": "node scripts/localdev/clean-dist.mjs",
    "bump-version": "node scripts/localdev/bump-version.mjs",
    "lint": "eslint ./src --fix",
    "data:copy": "node scripts/localdev/data_copy.mjs",
    "data:reset": "pnpm run build && node scripts/localdev/data_reset.mjs -f",
    "data:license": "cp foundry/foundry_dev_data/Config/license.json foundry/license.json",
    "server": "node scripts/localdev/start-server.mjs",
    "migration:create": "node scripts/localdev/create-migration.mjs",
    "packs:extract": "node scripts/pack-management/packs.mjs extract",
    "packs:build": "node scripts/pack-management/packs.mjs build",
    "packs:rebuild": "node scripts/pack-management/packs.mjs rebuild",
    "packs:transition": "node scripts/pack-management/transition-pack-management.mjs",
    "packs:verify": "node scripts/pack-management/verify-pack-workflow.mjs",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:install-browsers": "playwright install chromium"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "",
  "homepage": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "contributors": [
    {
      "name": "",
      "email": ""
    }
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@foundryvtt/foundryvtt-cli": "^3.0.3",
    "@league-of-foundry-developers/foundry-vtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#2315d2385e256f8e7011667683f0859f1f769fdf",
    "@playwright/test": "^1.61.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "axios": "^1.18.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "fs-extra": "^11.3.5",
    "glob": "^13.0.6",
    "marked": "^18.0.5",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "semantic-release": "^25.0.5",
    "semver": "^7.8.5",
    "simple-git": "^3.36.0",
    "socket.io-client": "^4.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "yargs": "^18.0.0",
    "yoctocolors": "^2.1.2"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "type": "module"
}
